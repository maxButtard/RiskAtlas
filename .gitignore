# ======================
# Protected Data (sensitive)
# ======================
data/raw/*
data/processed/*

# Allow sample data
!data/sample/
!data/sample/sample_dataset.xlsx

# ======================
# Outputs (generated files)
# ======================
outputs/*

# ======================
# Data files (global rule)
# ======================
*.xlsx
*.csv

# Allow sample CSV explicitly
!data/sample/sample_dataset.csv

# ======================
# Python
# ======================
__pycache__/
*.pyc

# ======================
# Environment
# ======================
.env